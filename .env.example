# -----------------------------------------------------------------------
# Copy this file to .env and fill in your values.
# .env is gitignored and should NEVER be committed.
# -----------------------------------------------------------------------

# ACLED credentials  (OAuth 2.0 — API keys were deprecated September 2025)
# Register for free at: https://acleddata.com/register/
# Use the same email + password you log in to myACLED with.
ACLED_EMAIL=your_email@example.com
ACLED_PASSWORD=your_myacled_password_here

# Optional: override the default ACLED base URL
# ACLED_BASE_URL=https://acleddata.com/api/acled/read

# HRDAG data is publicly available — no API key required.
# The ingest script downloads datasets directly from hrdag.org.
# If you have a local copy, set this path to skip the download.
# HRDAG_LOCAL_PATH=/path/to/hrdag_data.csv
